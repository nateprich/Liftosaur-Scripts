# API keys for the lifting engine + evals. Copy to .env and fill in.
# The live values currently also live in ~/Claude/.env (same machine), which the
# config loader falls back to automatically — so locally you may not need this.

# Liftosaur premium API key (read/write programs + history, + playground evals)
LIFTOSAUR_API_KEY=lftsk_xxx

# KeyLifts read-only API key (historical workout data, for starting-weight seed)
KEYLIFTS_API_KEY=kl_xxx
